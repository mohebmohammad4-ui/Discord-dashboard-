<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>إدارة السيرفر | Tokyo Community</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-main: #0f111a;
            --bg-card: #151824;
            --accent: #7289da;
            --accent-glow: #a5b4fc;
            --text: #f3f4f6;
            --text-muted: #9ca3af;
            --success: #10b981;
            --danger: #ef4444;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Tajawal', sans-serif; }
        body { background-color: var(--bg-main); color: var(--text); padding: 30px; }
        .container { max-width: 1200px; margin: 0 auto; }
        header { text-align: center; margin-bottom: 40px; }
        header h1 { font-size: 2.2rem; color: var(--text); font-weight: 900; }
        header p { color: var(--text-muted); margin-top: 5px; }
        .back-btn { display: inline-block; color: var(--accent-glow); text-decoration: none; margin-bottom: 20px; font-weight: bold; }
        .grid { display: grid; grid-template-columns: 1fr; gap: 30px; }
        @media (min-width: 768px) { .grid { grid-template-columns: 1fr 1fr; } }
        .card { background-color: var(--bg-card); border: 1px solid rgba(255,255,255,0.05); border-radius: 16px; padding: 25px; box-shadow: 0 10px 25px rgba(0,0,0,0.3); height: fit-content; }
        .card-title { font-size: 1.3rem; font-weight: 700; margin-bottom: 20px; color: var(--accent-glow); display: flex; align-items: center; gap: 10px; }
        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; margin-bottom: 8px; font-weight: 700; color: var(--text); }
        select, input[type="text"], input[type="number"] {
            width: 100%; padding: 12px 15px; background-color: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px; color: #fff; font-size: 1rem; transition: border-color 0.3s;
        }
        .slider-container { display: flex; align-items: center; gap: 15px; }
        input[type="range"] { flex: 1; accent-color: var(--accent); }
        .slider-value { background: rgba(114,137,218,0.2); padding: 4px 10px; border-radius: 6px; font-weight: bold; color: var(--accent-glow); }
        .btn { background-color: var(--accent); color: white; border: none; padding: 12px 20px; border-radius: 8px; font-size: 1rem; font-weight: 700; cursor: pointer; width: 100%; }
        .switch { position: relative; display: inline-block; width: 50px; height: 26px; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider-switch { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #374151; transition: .4s; border-radius: 34px; }
        .slider-switch:before { position: absolute; content: ""; height: 18px; width: 18px; left: 4px; bottom: 4px; background-color: white; transition: .4s; border-radius: 50%; }
        input:checked + .slider-switch { background-color: var(--success); }
        input:checked + .slider-switch:before { transform: translateX(24px); }
        .list-table { width: 100%; border-collapse: collapse; margin-top: 15px; }
        .list-table th, .list-table td { padding: 12px 10px; text-align: right; border-bottom: 1px solid rgba(255,255,255,0.05); }
        .delete-btn { background: none; border: none; color: var(--danger); cursor: pointer; font-weight: bold; }
    </style>
</head>
<body>
    <div class="container">
        <a href="/dashboard" class="back-btn">← العودة للوحة الخوادم</a>
        <header>
            <h1>إدارة سيرفر: <%= guild ? guild.name : 'Tokyo Server' %></h1>
            <p>تحكم بأنظمة التلفيل، الاختصارات، والردود التلقائية الذكية</p>
        </header>

        <div class="grid">
            <div class="card">
                <div class="card-title">✨ نظام المستويات ومكافآت الرتب</div>
                <form action="/dashboard/<%= guild.id %>/leveling" method="POST">
                    <div class="form-group" style="display: flex; justify-content: space-between; align-items: center;">
                        <label>تفعيل نظام الـ XP:</label>
                        <label class="switch">
                            <input type="checkbox" name="enabled" value="true" <%= (settings && settings.levelingSystem && settings.levelingSystem.enabled) ? 'checked' : '' %>>
                            <span class="slider-switch"></span>
                        </label>
                    </div>
                    <div class="form-group">
                        <label>مضاعف سرعة كسب الـ XP:</label>
                        <div class="slider-container">
                            <input type="range" name="xpRate" min="0.1" max="2.0" step="0.1" value="<%= (settings && settings.levelingSystem) ? settings.levelingSystem.xpRate : 1 %>" oninput="this.nextElementSibling.innerText = this.value + 'x'">
                            <span class="slider-value"><%= (settings && settings.levelingSystem) ? settings.levelingSystem.xpRate : 1 %>x</span>
                        </div>
                    </div>
                    <button type="submit" class="btn">حفظ إعدادات الـ XP العامة</button>
                </form>

                <hr style="border: 0; border-top: 1px solid rgba(255,255,255,0.05); margin: 25px 0;">
                
                <div style="font-weight: bold; margin-bottom: 15px; color: var(--accent-glow);">🎁 إضافة مكافأة رتبة لـ لفل:</div>
                <form action="/dashboard/<%= guild.id %>/leveling/add-role" method="POST" style="display: flex; gap: 10px; margin-bottom: 15px;">
                    <input type="number" name="level" placeholder="اللفل" style="width: 90px;" min="1" required>
                    <select name="roleId" required>
                        <option value="">-- اختر الرتبة --</option>
                        <% if (locals.serverRoles && serverRoles.length > 0) { %>
                            <% serverRoles.forEach(role => { %>
                                <option value="<%= role.id %>"><%= role.name %></option>
                            <% }) %>
                        <% } %>
                    </select>
                    <button type="submit" class="btn" style="width: auto; white-space: nowrap;">إضافة</button>
                </form>

                <table class="list-table">
                    <thead>
                        <tr><th>اللفل</th><th>الرتبة</th><th>إجراء</th></tr>
                    </thead>
                    <tbody>
                        <% if (settings && settings.levelingSystem && settings.levelingSystem.levelRoles && settings.levelingSystem.levelRoles.length > 0) { %>
                            <% settings.levelingSystem.levelRoles.forEach(lr => { %>
                                <tr>
                                    <td>مستوى <%= lr.level %></td>
                                    <td>
                                        <span style="color:var(--accent-glow)">
                                            <% const rName = locals.serverRoles ? serverRoles.find(r => r.id === lr.roleId)?.name : null; %>
                                            <%= rName || lr.roleId %>
                                        </span>
                                    </td>
                                    <td>
                                        <form action="/dashboard/<%= guild.id %>/leveling/delete-role" method="POST" style="display:inline;">
                                            <input type="hidden" name="levelRoleId" value="<%= lr._id || lr.id %>">
                                            <button type="submit" class="delete-btn">حذف</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="3" style="text-align:center; color:var(--text-muted);">لا توجد رتب مكافآت.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <div class="card">
                <div class="card-title">⌨️ نظام اختصارات الأوامر</div>
                <form action="/dashboard/<%= guild.id %>/shortcut" method="POST" style="display: flex; flex-direction: column; gap: 15px;">
                    <select name="commandName" required>
                        <option value="">-- اختر الأمر الأساسي --</option>
                        <% if (locals.botCommands && botCommands.length > 0) { %>
                            <% botCommands.forEach(cmd => { %>
                                <option value="<%= cmd.name %>">/<%= cmd.name %></option>
                            <% }) %>
                        <% } %>
                    </select>
                    <input type="text" name="shortcut" placeholder="الاختصار (مثال: c)" required>
                    <button type="submit" class="btn">ربط الاختصار</button>
                </form>

                <table class="list-table">
                    <thead>
                        <tr><th>الأمر</th><th>الاختصار</th><th>إجراء</th></tr>
                    </thead>
                    <tbody>
                        <% if (settings && settings.commandShortcuts && settings.commandShortcuts.length > 0) { %>
                            <% settings.commandShortcuts.forEach(sc => { %>
                                <tr>
                                    <td>/<%= sc.commandName %></td>
                                    <td><strong style="color: var(--success)"><%= sc.shortcut %></strong></td>
                                    <td>
                                        <form action="/dashboard/<%= guild.id %>/delete-shortcut" method="POST" style="display:inline;">
                                            <input type="hidden" name="shortcutId" value="<%= sc._id || sc.id %>">
                                            <button type="submit" class="delete-btn">حذف</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="3" style="text-align:center; color:var(--text-muted);">لا توجد اختصارات.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <div class="card" style="grid-column: 1 / -1;">
                <div class="card-title">💬 نظام الردود التلقائية</div>
                <form action="/dashboard/<%= guild.id %>/add-reply" method="POST" style="display: flex; gap: 15px; margin-bottom: 20px;">
                    <input type="text" name="trigger" placeholder="الكلمة" required style="flex:1;">
                    <input type="text" name="response" placeholder="الرد" required style="flex:1;">
                    <button type="submit" class="btn" style="width: auto;">إضافة</button>
                </form>

                <table class="list-table">
                    <thead>
                        <tr><th>الكلمة</th><th>الرد</th><th>إجراء</th></tr>
                    </thead>
                    <tbody>
                        <% if (settings && settings.autoReplies && settings.autoReplies.length > 0) { %>
                            <% settings.autoReplies.forEach(reply => { %>
                                <tr>
                                    <td><strong><%= reply.trigger %></strong></td>
                                    <td><%= reply.response %></td>
                                    <td>
                                        <form action="/dashboard/<%= guild.id %>/delete-reply" method="POST" style="display:inline;">
                                            <input type="hidden" name="replyId" value="<%= reply._id || reply.id %>">
                                            <button type="submit" class="delete-btn">حذف</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="3" style="text-align:center; color:var(--text-muted);">لا توجد ردود تلقائية.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>
