<div class="card" style="grid-column: 1 / -1; margin-top: 20px;">
    <div class="card-title">🛡️ التحكم بالأوامر وحظرها وتحديد الرتب</div>
    <p style="color: var(--text-muted); margin-bottom: 20px; font-size: 0.9rem;">يمكنك تعطيل أي أمر تماماً داخل السيرفر أو تحديد رتب معينة فقط يحق لها استخدامه.</p>

    <div style="display: grid; grid-template-columns: 1fr; gap: 20px;">
        <form action="/dashboard/<%= guild.id %>/commands/toggle" method="POST" style="display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap;">
            <div style="flex: 1; min-width: 200px;">
                <label style="display:block; margin-bottom: 8px; font-weight: bold;">اختر الأمر للتغيير (تعطيل/تفعيل):</label>
                <select name="commandName" required>
                    <option value="">-- اختر الأمر --</option>
                    <% if (locals.botCommands && botCommands.length > 0) { %>
                        <% botCommands.forEach(cmd => { %>
                            <option value="<%= cmd.name %>">
                                /<%= cmd.name %> <%= (settings.disabledCommands && settings.disabledCommands.includes(cmd.name)) ? '❌ (معطل حالياً)' : '✅ (مفعل)' %>
                            </option>
                        <% }) %>
                    <% } %>
                </select>
            </div>
            <button type="submit" class="btn" style="width: auto; padding: 12px 30px;">تعديل حالة الأمر</button>
        </form>

        <hr style="border: 0; border-top: 1px solid rgba(255,255,255,0.05);">

        <form action="/dashboard/<%= guild.id %>/commands/permissions" method="POST" style="display: flex; gap: 15px; flex-direction: column;">
            <div style="display: flex; gap: 15px; flex-wrap: wrap;">
                <div style="flex: 1; min-width: 200px;">
                    <label style="display:block; margin-bottom: 8px; font-weight: bold;">اختر الأمر الأساسي:</label>
                    <select name="commandName" required>
                        <option value="">-- اختر الأمر --</option>
                        <% if (locals.botCommands && botCommands.length > 0) { %>
                            <% botCommands.forEach(cmd => { %>
                                <option value="<%= cmd.name %>">Component: /<%= cmd.name %></option>
                            <% }) %>
                        <% } %>
                    </select>
                </div>
                
                <div style="flex: 1; min-width: 200px;">
                    <label style="display:block; margin-bottom: 8px; font-weight: bold;">الرتبة المسموح لها فقط بالاستخدام:</label>
                    <select name="roleId" required>
                        <option value="">-- اختر الرتبة المسموحة --</option>
                        <% if (locals.serverRoles && serverRoles.length > 0) { %>
                            <% serverRoles.forEach(role => { %>
                                <option value="<%= role.id %>"><%= role.name %></option>
                            <% }) %>
                        <% } %>
                    </select>
                </div>
            </div>
            <button type="submit" class="btn" style="width: 100%;">حفظ صلاحية الرتبة للأمر</button>
        </form>
    </div>
</div>
