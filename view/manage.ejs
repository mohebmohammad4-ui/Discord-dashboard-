<!DOCTYPE html>
<html>
<head>
  <title>تعديل إعدادات السيرفر</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .section-box {
      background: #1e293b;
      padding: 20px;
      margin: 20px auto;
      border-radius: 15px;
      max-width: 600px;
      text-align: right;
      direction: rtl;
      border: 1px solid #334155;
    }
    input, select {
      width: 100%;
      padding: 10px;
      margin-top: 8px;
      margin-bottom: 15px;
      background: #0f172a;
      border: 1px solid #334155;
      color: white;
      border-radius: 8px;
      box-sizing: border-box;
    }
    .reply-list {
      background: #0f172a;
      padding: 12px;
      border-radius: 8px;
      margin-bottom: 10px;
      font-size: 14px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-left: 4px solid #38bdf8;
    }
    .delete-btn {
      background: #ef4444;
      color: white;
      border: none;
      padding: 5px 10px;
      border-radius: 5px;
      cursor: pointer;
      font-size: 12px;
    }
    .delete-btn:hover { background: #dc2626; }
  </style>
</head>
<body>

  <div class="container" style="margin-top: 30px;">
    <a class="btn" href="/dashboard" style="background: #475569; float: left; margin-left: 20px;">⬅️ العودة للسيرفرات</a>
    <h2>لوحة تحكم سيرفر: <%= guild.name %></h2>
    <p style="color: #64748b;">قم بتخصيص أنظمة البوت لسيرفرك بسهولة</p>

    <div class="section-box">
      <h3>🤖 نظام الردود التلقائية (Auto Replies)</h3>
      <form action="/dashboard/<%= guild.id %>/add-reply" method="POST">
        <label>الكلمة المفتاحية (التي يرسلها العضو):</label>
        <input type="text" name="trigger" placeholder="مثال: السلام عليكم" required>
        
        <label>رد البوت التلقائي عليها:</label>
        <input type="text" name="response" placeholder="مثال: وعليكم السلام ورحمة الله وبركاته نورتنا!" required>
        
        <button type="submit" class="btn" style="width: 100%; margin-top: 0;">➕ إضافة الرد التلقائي</button>
      </form>

      <h4 style="margin-top: 20px; color: #38bdf8;">الردود الحالية المضافة:</h4>
      <% if (settings.autoReplies && settings.autoReplies.length > 0) { %>
        <% settings.autoReplies.forEach(reply => { %>
          <div class="reply-list">
            <div>
              <strong>الكلمة:</strong> <%= reply.trigger %> <br>
              <strong>الرد:</strong> <%= reply.response %>
            </div>
            <form action="/dashboard/<%= guild.id %>/delete-reply" method="POST" style="margin:0;">
              <input type="hidden" name="replyId" value="<%= reply._id %>">
              <button type="submit" class="delete-btn">🗑️ حذف</button>
            </form>
          </div>
        <% }) %>
      <% } else { %>
        <p style="font-size: 13px; color: #64748b;">لا توجد ردود تلقائية مضافة حالياً.</p>
      <% } %>
    </div>

    <div class="section-box">
      <h3>📈 نظام التلفيل والـ XP</h3>
      <form action="/dashboard/<%= guild.id %>/leveling" method="POST">
        <label>حالة النظام:</label>
        <select name="enabled">
          <option value="true" <%= settings.levelingSystem.enabled ? 'selected' : '' %>>مفعّل ✅</option>
          <option value="false" <%= !settings.levelingSystem.enabled ? 'selected' : '' %>>معطّل ❌</option>
        </select>

        <label>معدل كسب الخبرة (XP Multiplier):</label>
        <select name="xpRate">
          <option value="1" <%= settings.levelingSystem.xpRate === 1 ? 'selected' : '' %>>1x (طبيعي)</option>
          <option value="1.5" <%= settings.levelingSystem.xpRate === 1.5 ? 'selected' : '' %>>1.5x (متوسط)</option>
          <option value="2" <%= settings.levelingSystem.xpRate === 2 ? 'selected' : '' %>>2x (مضاعف)</option>
        </select>

        <button type="submit" class="btn" style="width: 100%; margin-top: 0; background: #10b981;">💾 حفظ إعدادات التلفيل</button>
      </form>
    </div>

    <div class="section-box" style="border-left: 4px solid #f59e0b;">
      <h3>🔗 اختصارات أوامر البوت (Shortcuts)</h3>
      <p style="font-size: 12px; color: #94a3b8; margin-top:-5px;">💡 تنبيه: يرجى كتابة الاختصار بدون علامة الـ (/) لكي يقرأه البوت كأمر نصي في الشات (مثال: اكتب <code style="color:#fbbf24;">a</code> أو <code style="color:#fbbf24;">!a</code>).</p>
      
      <form action="/dashboard/<%= guild.id %>/shortcut" method="POST">
        <label>اسم الأمر الأساسي (بدون /):</label>
        <input type="text" name="commandName" placeholder="مثال: avatar أو help" required>
        
        <label>الاسم المختصر البديل (الذي سيكتبه العضو في الشات):</label>
        <input type="text" name="shortcut" placeholder="مثال: !a أو !h أو صورة" required>
        
        <button type="submit" class="btn" style="width: 100%; margin-top: 0; background: #f59e0b;">✨ إضافة الاختصار</button>
      </form>

      <h4 style="margin-top: 20px; color: #fbbf24;">الاختصارات الحالية:</h4>
      <% if (settings.commandShortcuts && settings.commandShortcuts.length > 0) { %>
        <% settings.commandShortcuts.forEach(sc => { %>
          <div class="reply-list" style="border-left-color: #f59e0b;">
            <div>
              <strong>الأمر الأساسي:</strong> /<%= sc.commandName %> <br>
              <strong>الاختصار في الشات:</strong> <%= sc.shortcut %>
            </div>
            <form action="/dashboard/<%= guild.id %>/delete-shortcut" method="POST" style="margin:0;">
              <input type="hidden" name="shortcutId" value="<%= sc._id %>">
              <button type="submit" class="delete-btn">🗑️ حذف</button>
            </form>
          </div>
        <% }) %>
      <% } else { %>
        <p style="font-size: 13px; color: #64748b;">لا توجد اختصارات مضافة حالياً.</p>
      <% } %>
    </div>

  </div>

</body>
</html>
