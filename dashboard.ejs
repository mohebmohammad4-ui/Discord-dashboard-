<!DOCTYPE html>
<html>
<head>
  <title>Dashboard - Select Server</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <div class="container" style="margin-top: 50px;">
    <h2>أهلاً بك، <%= user.username %> 👋</h2>
    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" width="80" style="border-radius:50%; border: 3px solid #5865F2;">
    
    <br><br>
    <a class="btn" href="/logout" style="background-color: #ed4245;">تسجيل الخروج</a>

    <h3 style="margin-top: 40px; color: #94a3b8;">اختر السيرفر لتعديل إعدادات البوت:</h3>

    <div class="grid">
      <% if (guilds && guilds.length > 0) { %>
        <% guilds.forEach(g => { %>
          <div class="card">
            <% if (g.icon) { %>
              <img src="https://cdn.discordapp.com/icons/<%= g.id %>/<%= g.icon %>.png" width="60" style="border-radius: 50%; margin-bottom: 10px;">
            <% } else { %>
              <div style="width: 60px; height: 60px; background: #5865F2; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 10px; font-weight: bold;">
                <%= g.name.charAt(0) %>
              </div>
            <% } %>
            <h4><%= g.name %></h4>
            <p style="font-size: 12px; color: #64748b; margin-bottom: 15px;">ID: <%= g.id %></p>
            <a class="btn" href="/dashboard/<%= g.id %>" style="width: 80%; padding: 8px; font-size: 14px;">دخول اللوحة</a>
          </div>
        <% }) %>
      <% } else { %>
        <p style="color: #ed4245; grid-column: 1/-1;">⚠️ لا توجد سيرفرات تمتلك فيها صلاحية Administrator أو أن البوت غير متواجد بها.</p>
      <% } %>
    </div>
  </div>

</body>
</html>
